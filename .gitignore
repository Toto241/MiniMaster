# Ignore Node dependencies and build output
node_modules/
lib/
coverage/

# Ignore Android build directories
**/build/
.gradle/

# IntelliJ/Android Studio project files
.idea/
*.iml

# VS Code workspace files
.vscode/
*.code-workspace

# Local configuration files
local.properties
*.hprof

# Environment files (contain secrets – never commit)
.env
.env.local
.env.*.local
# .env.example is intentionally NOT ignored (it's the safe template)
.security-test.env
scripts/security-test.env

# Firebase app configs (must never be committed)
**/google-services.json
*_google-services.json
**/GoogleService-Info.plist
serviceAccountKey.json
serviceAccountKey*.json
*firebase-adminsdk*.json
# Keep only safe templates in git
!**/google-services.template.json
!**/serviceAccountKey.template.json

# Generated per-panel Firebase configuration (written by setup wizard,
# contains real API keys). Templates remain checked in.
admin-panel/firebase-config.js
web-control/firebase-config.js
parent-panel/firebase-config.js
child-panel/firebase-config.js
!**/firebase-config.template.js

# OS-specific files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.tmp_*
tmp_*
*.log
coverage_report.txt
test_output.txt
test-output.txt
test-json.txt
# Ad-hoc Jest/PowerShell debug dumps (Welle 0 Cleanup)
wave*-errors.txt
wave*-failures.txt
wave*-json.txt
test/wave*-errors.txt
test/wave*-failures.txt
test/wave*-json.txt

# Regenerierbare Tool-Ausgaben / Artefakte (Repo-Cleanup)
lint_output*.txt
lint-output.txt
test-ci-output.txt
build-output.txt
audit_report.txt
*.exe
admin-panel.zip

# Python local environments and bytecode
.venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Swift / Xcode build artefacts
**/.build/
*.xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# GitHub Pages (lokal generiert; Deploy via Actions)
site/

# Lokale Publisher-Daten fuer setup-github-pages.ps1
config/legal-publisher.json
