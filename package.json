{
  "name": "minimaster",
  "version": "1.0.0",
  "description": "This repository contains the experimental implementation of the child application of the **Mini\u2011Master** project and accompanying Firebase Cloud Functions.",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .js,.ts",
    "test": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:ci": "jest --config jest.config.cjs --runInBand",
    "test:watch": "jest --watch",
    "desktop-start": "electron desktop/main.js",
    "desktop-operator": "electron desktop/main.js --operator",
    "test:rules:structural": "jest --config jest.config.cjs --runInBand test/firestore-rules.test.ts",
    "test:rules:emulator": "npx firebase-tools emulators:exec --project demo-minimaster --only firestore \"node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --config jest.config.cjs --runInBand test/firestore-rules.emulator.test.ts\"",
    "validate:readiness": "npm run build && npm run lint && npm run test:ci && npm run test:rules:structural",
    "ci:revalidate": "pwsh ./scripts/revalidate-release-gates.ps1",
    "ci:revalidate:rerun": "pwsh ./scripts/revalidate-release-gates.ps1 -RerunLatestFailed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@types/node": "^22.15.29",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "googleapis": "^155.0.1",
    "openai": "^6.10.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "electron": "^36.4.0",
    "eslint": "^8.57.1",
    "firebase-functions-test": "^3.4.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
