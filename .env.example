# MiniMaster – Cloud Functions Umgebungsvariablen
# ================================================
# Dieses .env.example dient als Vorlage. Kopiere es nach .env (wird von .gitignore ausgeschlossen)
# und setze die echten Werte ein.
#
# Firebase Cloud Functions (Gen 1): Variablen per firebase functions:secrets:set <VAR>
# oder als Process-Env in .env-Dateien im gleichen Verzeichnis verwenden.
# Siehe: https://firebase.google.com/docs/functions/config-env

# ---- KI-Integration ------------------------------------------------

# Gemini API-Key (Google AI Studio oder Vertex AI)
# Erforderlich für: Support-Ticket-Automatik, Gemini-Assistent im Admin-Panel,
# FCM-Analyse-Trigger (onChildDeviceUpdateV2)
GEMINI_API_KEY=

# Gemini-Modell (optional, Fallback: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API-Key (optionaler Fallback, falls Gemini nicht konfiguriert)
# Erforderlich für: Support-Ticket-Fallback in src/support.ts
OPENAI_API_KEY=

# OpenAI-Fallback aktivieren ("true" / "false", Fallback: false)
OPENAI_FALLBACK_ENABLED=false

# ---- URLs ----------------------------------------------------------

# Basis-URL für rechtliche Richtlinien (Privacy Policy, AGB)
# Wird in src/legal.ts für automatisch generierte contentUrl verwendet.
# Fallback: https://minimaster.app/legal
LEGAL_POLICY_BASE_URL=https://minimaster.app/legal

# Basis-URL für Kopplungslinks (QR-Code / Deep-Link an Eltern-App)
# Wird in src/pairing.ts für generatePairingLink verwendet.
# Fallback: https://minimaster.app/pair
PAIRING_LINK_BASE_URL=https://minimaster.app/pair

# ---- Sicherheit / Feature-Flags ------------------------------------

# Legacy-SecretKey-Auth deaktivieren ("true" schaltet IMEI/secretKey-Endpoints ab)
# Standard: false (Auth läuft weiter). Erst auf "true" setzen wenn alle Clients
# auf context.auth migriert sind (siehe docs/LEGACY_AUTH_INVENTORY.md).
DISABLE_LEGACY_SECRETKEY_AUTH=false

# ---- Apple App Store Server API ------------------------------------

# Apple Bundle ID (z.B. com.minimaster.masterapp)
APPLE_BUNDLE_ID=com.minimaster.masterapp

# App Store Connect Issuer ID (aus Keys & IDs)
APPLE_ISSUER_ID=

# App Store Connect Key ID (aus Keys & IDs)
APPLE_KEY_ID=

# PKCS8 Private Key (-----BEGIN EC PRIVATE KEY----- …)
APPLE_PRIVATE_KEY=

# Umgebung: "production" oder "sandbox"
APPLE_ENVIRONMENT=production

# ---- Sonstiges -----------------------------------------------------

# Pfad zur Wissensdatenbank für den Support-Agenten (knowledge_base.txt)
# Wird in src/support.ts für kontextbasierte Antworten verwendet.
# Fallback: automatische Suche im Projektverzeichnis
KNOWLEDGE_BASE_PATH=./knowledge_base.txt

# ---- Automatisch gesetzt (nicht manuell setzen) --------------------
# GCLOUD_PROJECT       – von Firebase Runtime gesetzt
# FIREBASE_CONFIG      – von Firebase Runtime gesetzt
# FUNCTIONS_EMULATOR   – von Firebase Emulator gesetzt (true im lokalen Betrieb)
# NODE_ENV             – von Test-Runner gesetzt (test)
