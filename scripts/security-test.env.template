# Copy to .security-test.env or scripts/security-test.env and fill with real values.
# Never commit real credentials to git.

SECURITY_TEST_ADMIN_EMAIL=
SECURITY_TEST_UNAUTHORIZED_ACCESS_FAILED=true
SECURITY_TEST_FUNCTIONS_DEPLOYED=true

# Optional absolute or relative path. If omitted, test runner uses ./serviceAccountKey.json
SECURITY_TEST_SERVICE_ACCOUNT=serviceAccountKey.json
