rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user is an admin.
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // Helper function to check if the authenticated user is a support agent.
    function isSupport() {
      return isSignedIn() && request.auth.token.role == 'support';
    }

    // Helper function to check if the authenticated user is an auditor.
    function isAuditor() {
      return isSignedIn() && request.auth.token.role == 'auditor';
    }

    // Any operator role (admin, support, or auditor).
    function isOperator() {
      return isAdmin() || isSupport() || isAuditor();
    }

    // Support or admin role.
    function isSupportOrAdmin() {
      return isAdmin() || isSupport();
    }

    // --- SUPPORT TICKETS COLLECTION ---
    // Users can create and read their own tickets
    // Admins and support agents can read all tickets and update their status
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.masterImei || isSupportOrAdmin());
      allow create, update, delete: if false; // Support tickets are managed via callable functions / Admin SDK only.

      match /conversationHistory/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.masterImei
          || isSupportOrAdmin()
        );
        allow write: if false; // Only Cloud Functions (Admin SDK)
      }
    }

    // --- SUPPORT ACCESS GRANTS COLLECTION ---
    // Users can create and manage their own grants
    // Admins and support agents can read all grants
    match /supportAccessGrants/{grantId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.masterImei || isSupportOrAdmin());
      allow create, update, delete: if false; // Grants are issued and revoked server-side only.
    }

    // --- MASTERS COLLECTION ---
    // Masters are identified by their IMEI (document ID).
    // A master can only read/write their own document.
    // Admins can read master data ONLY through the support interface (no blanket access)
    match /masters/{masterId} {
      allow read: if isSignedIn() && (request.auth.uid == masterId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == masterId;
    }

    // --- CHILDREN COLLECTION ---
    // Children are linked to masters via the 'masterImei' field.
    // A child document can be read/written by:
    // 1. The master who owns the child (masterImei matches auth.uid)
    // 2. The child device itself (childImei matches auth.uid)
    // 3. Admins (for support purposes)
    match /children/{childId} {
      allow read: if isSignedIn() && (
        resource.data.masterImei == request.auth.uid ||
        childId == request.auth.uid ||
        isAdmin()
      );
      allow create: if false; // Only Cloud Functions (Admin SDK) can create
      allow update: if isSignedIn() && (resource.data.masterImei == request.auth.uid || childId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.masterImei == request.auth.uid || isAdmin());
    }

    // --- TASKS COLLECTION (nested under children) ---
    // Tasks are nested under children: /children/{childId}/tasks/{taskId}
    // Access rules:
    // - Master (owner of child) can read/write all tasks
    // - Child device can read/write their own tasks
    // - Admins can read tasks for support purposes
    match /children/{childId}/tasks/{taskId} {
      // Get the child document to check ownership
      function getChild() {
        return get(/databases/$(database)/documents/children/$(childId));
      }

      function isMasterOfChild() {
        return isSignedIn() && getChild().data.masterImei == request.auth.uid;
      }

      function isChildDevice() {
        return isSignedIn() && childId == request.auth.uid;
      }

      function isValidTaskSchema() {
        let d = request.resource.data;
        return d.keys().hasOnly([
            'description', 'deadline', 'status', 'photoUrl', 'createdAt',
            'completedAt', 'updatedAt', 'masterImei', 'rejectionReason', 'aiAnalysis',
            'unlockDuration', 'unlockUntil'
          ])
          && d.description is string
          && d.description.size() > 0
          && d.description.size() < 1000
          && d.status is string
          && d.status in ['pending', 'pending_approval', 'approved', 'rejected']
          && (!('photoUrl' in d) || d.photoUrl is string || d.photoUrl == null)
          && (!('rejectionReason' in d) || d.rejectionReason is string)
          && (!('deadline' in d) || d.deadline is timestamp)
          && (!('createdAt' in d) || d.createdAt is timestamp)
          && (!('completedAt' in d) || d.completedAt is timestamp)
          && (!('updatedAt' in d) || d.updatedAt is timestamp)
          && (!('unlockDuration' in d) || d.unlockDuration is int)
          && (!('unlockUntil' in d) || d.unlockUntil is timestamp)
          && d.masterImei is string;
      }

      allow read: if isMasterOfChild() || isChildDevice() || isAdmin();
      // Only master can create tasks, and the task document must satisfy the schema.
      allow create: if isMasterOfChild() && isValidTaskSchema();

      // Both master and child device can update, but updates must satisfy the same schema.
      allow update: if (isMasterOfChild() || isChildDevice()) && isValidTaskSchema();

      allow delete: if isMasterOfChild(); // Only master can delete tasks
    }

    // --- PAIRING CODES COLLECTION ---
    // Pairing codes are managed by Cloud Functions.
    // Read access is allowed for authenticated users (to validate codes).
    // Write access is restricted to Cloud Functions (server-side only).
    match /pairingCodes/{codeId} {
      allow read, write: if false; // Only Cloud Functions (Admin SDK)
    }

    // --- PAIRING TOKENS COLLECTION ---
    // Similar to pairing codes, managed by Cloud Functions.
    match /pairingTokens/{tokenId} {
      allow read, write: if false; // Only Cloud Functions (Admin SDK)
    }

    // --- SUBSCRIPTIONS COLLECTION ---
    // Subscriptions are linked to masters via 'masterId' field.
    // A master can only read their own subscription.
    // Write access is restricted to Cloud Functions.
    // Admins can read subscriptions for support purposes.
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && (resource.data.masterId == request.auth.uid || isAdmin());
      allow write: if false; // Only Cloud Functions can write
    }

    // --- USAGE HISTORY COLLECTION (nested under children) ---
    // Used by reportDailyUsage to track screen time
    match /children/{childId}/usageHistory/{date} {
      // Get the child document to check ownership
      function getChildForHistory() {
        return get(/databases/$(database)/documents/children/$(childId));
      }

      allow read: if isSignedIn() && (getChildForHistory().data.masterImei == request.auth.uid || childId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && childId == request.auth.uid; // Only child can report usage

      // Validate usage history data structure
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['date', 'totalUsageMillis', 'updatedAt'])
        && request.resource.data.date is string
        && request.resource.data.totalUsageMillis is number;
    }

    // --- TAMPER EVENTS COLLECTION (nested under children) ---
    // Records device tamper/bypass attempts reported by child devices
    // Read for master (owner) and admins, write only via Cloud Functions
    match /children/{childId}/tamperEvents/{eventId} {
      function getChildForTamper() {
        return get(/databases/$(database)/documents/children/$(childId));
      }

      allow read: if isSignedIn() && (getChildForTamper().data.masterImei == request.auth.uid || isAdmin());
      allow write: if false; // Only Cloud Functions can write
    }

    // --- COMMANDS COLLECTION (nested under children) ---
    // Stores master→child policy commands for bidirectional Android/iOS control-plane.
    // Commands are created only by Cloud Functions (Admin SDK) and acknowledged by
    // the child device itself. The owning master can read commands for diagnostics.
    match /children/{childId}/commands/{commandId} {
      function getChildForCmd() {
        return get(/databases/$(database)/documents/children/$(childId));
      }

      // Master or child device can read; admin for support
      allow read: if isSignedIn() && (
        getChildForCmd().data.masterImei == request.auth.uid ||
        childId == request.auth.uid ||
        isAdmin()
      );

      // Commands are created exclusively by Cloud Functions (Admin SDK)
      allow create: if false;

      // Only the child device itself may update status (ack)
      allow update: if isSignedIn()
        && childId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'ackedAt', 'errorCode']);

      allow delete: if false;
    }

    // --- EVENTS COLLECTION (nested under children) ---
    // Stores child→master events (usage_report, tamper_event, command_ack, etc.).
    // Events are immutable once created; master reads them for monitoring.
    match /children/{childId}/events/{eventId} {
      function getChildForEvent() {
        return get(/databases/$(database)/documents/children/$(childId));
      }

      // Master or admin can read events
      allow read: if isSignedIn() && (
        getChildForEvent().data.masterImei == request.auth.uid ||
        isAdmin()
      );

      // Only the child device itself may publish events
      allow create: if isSignedIn()
        && childId == request.auth.uid
        && request.resource.data.keys().hasOnly([
            'eventId', 'eventType', 'payload', 'idempotencyKey',
            'senderPlatform', 'createdAt'
          ])
        && request.resource.data.eventType is string
        && request.resource.data.idempotencyKey is string
        && request.resource.data.senderPlatform in ['android', 'ios'];

      allow update, delete: if false; // Events are immutable
    }

    // --- DENY OLD NESTED FAMILY STRUCTURE ---
    // Prevent confusion by explicitly denying access to the old data model.
    match /families/{familyId} {
      allow read, write: if false;
    }
    match /families/{familyId}/children/{childId} {
      allow read, write: if false;
    }

    // --- AUDIT LOGS COLLECTION ---
    // Audit logs track all system operations for compliance and security
    // Read-only for admins and auditors, write access only via Cloud Functions
    match /audit_logs/{logId} {
      allow read: if isAdmin() || isAuditor();
      allow write: if false; // Only Cloud Functions can write
    }

    // --- PERFORMANCE METRICS COLLECTION ---
    // Performance metrics track function execution times and success rates
    // Read-only for admins and auditors, write access only via Cloud Functions
    match /performance_metrics/{metricId} {
      allow read: if isAdmin() || isAuditor();
      allow write: if false; // Only Cloud Functions can write
    }

    // --- ERROR LOGS COLLECTION ---
    // Error logs track all system errors for debugging and monitoring
    // Read-only for admins and auditors, write access only via Cloud Functions
    match /error_logs/{errorId} {
      allow read: if isAdmin() || isAuditor();
      allow write: if false; // Only Cloud Functions can write
    }

    // --- ERROR SUMMARIES COLLECTION ---
    // Aggregated error summaries for admin dashboards
    // Read-only for admins and auditors, write access only via Cloud Functions
    match /error_summaries/{summaryId} {
      allow read: if isAdmin() || isAuditor();
      allow write: if false; // Only Cloud Functions can write
    }

    // --- OPERATOR CONFIG COLLECTION ---
    // Runtime configuration for operator dashboard (cloud + AI settings)
    // All operators can read, only admins can write
    match /operatorConfig/{docId} {
      allow read: if isOperator();
      allow write: if isAdmin();
    }

    // --- LEGAL POLICY COLLECTIONS ---
    // Policies are published through admin-only Cloud Functions and may be read by
    // authenticated users for support/audit purposes.
    match /legalPolicies/{policyId} {
      allow read: if isSignedIn();
      allow write: if false; // Only Cloud Functions can publish or retire policies
    }

    match /masterLegalConsents/{consentId} {
      allow read: if isSignedIn() && (resource.data.masterImei == request.auth.uid || isAdmin() || isAuditor());
      allow write: if false; // Only Cloud Functions can record or flag re-consent
    }
  }
}
