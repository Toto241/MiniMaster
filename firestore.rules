rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for masters collection (flat structure to match Cloud Functions)
    // Masters are identified by IMEI and authenticated via secretKey in Cloud Functions
    match /masters/{masterId} {
      // Allow read/write for authenticated users only
      // Note: Authentication is handled in Cloud Functions via secretKey validation
      allow read, write: if isSignedIn();
    }

    // Rules for children collection (flat structure to match Cloud Functions)  
    // Children are linked to masters via masterImei field
    match /children/{childId} {
      // Allow read/write for authenticated users only
      // Note: Authorization is handled in Cloud Functions via master-child relationship
      allow read, write: if isSignedIn();
    }

    // Rules for tasks, nested under children (matches Cloud Functions)
    match /children/{childId}/tasks/{taskId} {
      allow read, write: if isSignedIn();
      
      // Validate task data structure when writing
      // Fields written by createTask: description, deadline, status, createdAt, masterImei
      // Fields written by completeTask: status, photoUrl, completedAt, updatedAt
      // Fields written by approveTask: status, updatedAt
      // Fields written by analyzeTaskPhoto: aiAnalysis
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['description', 'status', 'photoUrl', 'createdAt', 'updatedAt', 'deadline', 'completedAt', 'masterImei', 'aiAnalysis'])
        && request.resource.data.description is string
        && request.resource.data.description.size() < 500
        && request.resource.data.status is string
        && request.resource.data.status in ['pending', 'pending_approval', 'approved']
        && (!('photoUrl' in request.resource.data) || request.resource.data.photoUrl is string || request.resource.data.photoUrl == null)
        && request.resource.data.deadline is timestamp;

      // Allow delete for authenticated users (handled by Cloud Functions)
      allow delete: if isSignedIn();
    }

    // Rules for pairing codes (flat structure to match Cloud Functions)
    match /pairingCodes/{codeId} {
      // Allow read/write for authenticated users only
      // Note: Cloud Functions handle the creation and validation logic
      allow read, write: if isSignedIn();
    }

    // Rules for pairing tokens (flat structure to match Cloud Functions)
    match /pairingTokens/{tokenId} {
      // Allow read/write for authenticated users only
      // Note: Cloud Functions handle the creation and validation logic
      allow read, write: if isSignedIn();
    }

    // Rules for subscriptions collection (used by admin panel and verifyPurchase)
    match /subscriptions/{subscriptionId} {
      // Allow read/write for authenticated users only
      // Note: Admin authorization is handled in Cloud Functions via custom claims
      allow read, write: if isSignedIn();
    }

    // Rules for usage history sub-collection (used by reportDailyUsage)
    match /children/{childId}/usageHistory/{date} {
      allow read, write: if isSignedIn();
      
      // Validate usage history data structure
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['date', 'totalUsageMillis', 'updatedAt'])
        && request.resource.data.date is string
        && request.resource.data.totalUsageMillis is number;
    }

    // Deny access to the old nested family structure to prevent confusion
    match /families/{familyId} {
      allow read, write: if false;
    }
    match /families/{familyId}/children/{childId} {
      allow read, write: if false;
    }
  }
}
