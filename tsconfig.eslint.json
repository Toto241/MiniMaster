{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "index.ts",
    "firebase.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "lib",
    "coverage",
    "web-control",
    "masterApp",
    "childApp",
    "admin-panel",
    "scripts"
  ]
}
