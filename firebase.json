{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "childApp",
        "masterApp",
        "web-control",
        "admin-panel",
        "docs",
        "test",
        "coverage",
        "build",
        "desktop",
        "parent-panel",
        "child-panel",
        "ai-toolkit-multi-agent",
        "iosChildApp",
        "iosMasterApp",
        "iosSharedServices",
        "scripts",
        "codeql-custom-queries-actions",
        ".github",
        ".vscode",
        ".idea",
        ".firebase",
        ".gradle",
        ".kotlin",
        ".mypy_cache",
        ".venv",
        ".backup_import_*",
        "*.hprof",
        "*.pdf",
        "*.exe",
        "*.md",
        "*.bat",
        "*.sh",
        "*.html",
        "gradle",
        "gradlew",
        "gradlew.bat",
        "settings.gradle",
        "build.gradle",
        "gradle.properties",
        "local.properties",
        "detekt.yml"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "web-control",
      "public": "web-control",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=604800"
            }
          ]
        },
        {
          "source": "**",
          "headers": [
            {
              "key": "X-Content-Type-Options",
              "value": "nosniff"
            },
            {
              "key": "X-Frame-Options",
              "value": "DENY"
            },
            {
              "key": "X-XSS-Protection",
              "value": "1; mode=block"
            },
            {
              "key": "Referrer-Policy",
              "value": "strict-origin-when-cross-origin"
            },
            {
              "key": "Content-Security-Policy",
              "value": "default-src 'self'; script-src 'self' https://www.gstatic.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.cloudfunctions.net; img-src 'self' data: https:; font-src 'self';"
            },
            {
              "key": "Strict-Transport-Security",
              "value": "max-age=63072000; includeSubDomains; preload"
            },
            {
              "key": "Permissions-Policy",
              "value": "camera=(), microphone=(), geolocation=(), payment=()"
            }
          ]
        }
      ]
    },
    {
      "target": "admin-panel",
